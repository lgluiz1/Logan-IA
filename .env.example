# ──────────────────────────────────────────────
# Logan AI — Environment Variables
# ──────────────────────────────────────────────

# Ambiente
LOGAN_ENV=development
# LOGAN_ENV=production

# Motorista
DRIVER_NAME=Luiz

# Logging
LOGAN_LOG_LEVEL=INFO

# Redis
# OBD-II
# OBD_PORT=/dev/ttyUSB0

# ESP32
# Redis (Event Bus)
# Se rodando o main.py no PC host, use localhost. Dentro do Docker é redis://redis:6379
REDIS_URL=redis://localhost:6379

# Whisper STT
# Se rodando no PC host, use localhost. Dentro do docker é http://whisper:9000
WHISPER_URL=http://localhost:9000
WHISPER_MODEL=small

# Kokoro TTS
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=pf_dora

# Grafana
GRAFANA_PASSWORD=logan2024

# AI Gateway (opcional — sem internet funciona com base local)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
